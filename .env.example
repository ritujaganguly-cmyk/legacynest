# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# App Configuration
VITE_APP_URL=http://localhost:5173

# Admin email — used to show the Admin sidebar link and protect /admin routes
VITE_ADMIN_EMAIL=admin@legacynest.co.in

# Database: run supabase/000_initial_schema.sql on a fresh project,
# then supabase/migrations/041_schema_gaps.sql, then 042_user_consent.sql
# Schema layout:
#   config.*   — static lookup data (disability types, govt schemes)
#   public.*   — non-sensitive user data (care circle, plan progress)
#   protected.*— SPDI data (medical, financial, legal, disability, vault)
